{
  "version": 2,
  "installCommand": "npm --prefix backend install && npm run install:frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "myreactapp/build",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|static/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
