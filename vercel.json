{
  "version": 2,
  "installCommand": "npm run install:frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "myreactapp/build",
  "rewrites": [
    {
      "source": "/((?!static/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
