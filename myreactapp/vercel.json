{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|static/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
