# AgriConnect React Frontend — environment variables
# Copy to .env if you need to override the backend URL (e.g. for production)

# URL of the AgriConnect backend (no trailing slash)
# Default (localhost dev): http://localhost:5000
# REACT_APP_BACKEND_URL=https://your-backend.vercel.app

# Do not put weather, Gemini, mandi, session, or admin secrets in frontend env.
# Weather calls go through the backend /api/weather proxy.
