{
  "name": "agriconnect-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "npm --prefix myreactapp run build",
    "install:frontend": "npm --prefix myreactapp install",
    "start:frontend": "npm --prefix myreactapp start",
    "start:backend": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev"
  },
  "engines": {
    "node": ">=18"
  }
}
