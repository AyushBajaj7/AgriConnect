# AgriConnect Backend environment variables
# Copy this file to .env and fill in your values

# Optional: server port (default: 5000)
PORT=5000

# Optional: comma-separated frontend origins allowed through CORS
# Example:
# FRONTEND_ORIGIN=https://agri-connect-gamma-one.vercel.app
FRONTEND_ORIGIN=

# Gemini API key used by the chatbot backend
GEMINI_API_KEY=

# Secure login configuration
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Optional cookie overrides for cross-site deployments
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=none

# Agmarknet API Key for live price fetching
AGMARKNET_API_KEY=

# Optional mandi source override and cache behavior
# Default current-daily source:
# https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
AGMARKNET_URL=
PRICE_LIVE_UPSTREAM_TIMEOUT_MS=30000
PRICE_LIVE_FETCH_LIMIT=1000
PRICE_LIVE_FETCH_PAGES=5
PRICE_LIVE_REFRESH_MINUTES=10
PRICE_LOGIN_REFRESH_HOURS=24
PRICE_CACHE_MAX_AGE_HOURS=12

# Optional AI fallback. Keep true so chatbot still answers if Gemini fails.
AI_LOCAL_FALLBACK=true

# Optional application firewall settings
FIREWALL_MAX_REQUESTS_PER_MINUTE=180
FIREWALL_MAX_URL_LENGTH=2048
FIREWALL_DENY_IPS=
FIREWALL_ALLOW_IPS=
