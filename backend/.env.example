# AgriConnect Backend environment variables
# Copy this file to .env and fill in your values

# Optional: server port (default: 5000)
PORT=5000

# Optional: comma-separated frontend origins allowed through CORS
# Example:
# FRONTEND_ORIGIN=https://agri-connect-gamma-one.vercel.app
FRONTEND_ORIGIN=

# Gemini API key used by the chatbot backend
GEMINI_API_KEY=

# Secure login configuration
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Optional cookie overrides for cross-site deployments
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=none
